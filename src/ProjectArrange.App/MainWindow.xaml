<Window x:Class="ProjectArrange.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProjectArrange.App"
        mc:Ignorable="d"
        Title="ProjectArrange" Height="760" Width="1100"
        Icon="pack://application:,,,/Assets/App.ico">
    <Grid>
        <TabControl Margin="12">
            <TabItem Header="Diagnostics">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Refresh" Command="{Binding Diagnostics.RefreshCommand}" />
                        <Button Content="Write Probe" Command="{Binding Diagnostics.WriteProbeCommand}" />
                        <TextBlock Margin="10,6,0,0" Text="{Binding Diagnostics.Probe}" Foreground="{StaticResource Brush.Muted}" />
                    </StackPanel>

                    <TextBox Grid.Row="1" Margin="0,10,0,10" Text="{Binding Diagnostics.Paths}" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                    <TextBox Grid.Row="2" Text="{Binding Diagnostics.Tools}" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                    <TextBlock Grid.Row="3" Text=" " />
                </Grid>
            </TabItem>

            <TabItem Header="Config">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Load User Config" Command="{Binding Config.LoadUserConfigCommand}" />
                        <Button Content="Save User Config" Margin="10,0,0,0" Command="{Binding Config.SaveUserConfigCommand}" />
                        <Button Content="Refresh Effective" Margin="10,0,0,0" Command="{Binding Config.RefreshEffectiveCommand}" />
                        <TextBlock Margin="10,6,0,0" Text="{Binding Config.Status}" Foreground="{StaticResource Brush.Muted}" />
                    </StackPanel>

                    <TextBox Grid.Row="1" Margin="0,10,0,10" Text="{Binding Config.UserJson, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                    <TextBox Grid.Row="2" Text="{Binding Config.Effective}" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                </Grid>
            </TabItem>

            <TabItem Header="AI">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Start Python Server" Command="{Binding Ai.StartPythonServerCommand}" />
                        <Button Content="Send" Margin="10,0,0,0" Command="{Binding Ai.SendCommand}" />
                        <Button Content="Refresh" Margin="10,0,0,0" Command="{Binding Ai.RefreshCommand}" />
                        <TextBlock Margin="10,6,0,0" Text="{Binding Ai.Status}" Foreground="{StaticResource Brush.Muted}" />
                    </StackPanel>

                    <TextBox Grid.Row="1" Margin="0,10,0,10" Text="{Binding Ai.System, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                    <TextBox Grid.Row="2" Text="{Binding Ai.Prompt, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                    <TextBox Grid.Row="3" Text="{Binding Ai.Response}" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                </Grid>
            </TabItem>

            <TabItem Header="Process">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <TextBox Width="160" Text="{Binding Process.FileName, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Width="520" Margin="10,0,0,0" Text="{Binding Process.Arguments, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Width="240" Margin="10,0,0,0" Text="{Binding Process.WorkingDirectory, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Width="90" Margin="10,0,0,0" Text="{Binding Process.TimeoutMs, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Content="Run" Margin="10,0,0,0" Command="{Binding Process.RunCommand}" />
                    </StackPanel>

                    <TextBlock Grid.Row="1" Margin="0,10,0,10" Text="FileName / Arguments / WorkingDirectory / TimeoutMs" Foreground="{StaticResource Brush.Muted}" />
                    <TextBox Grid.Row="2" Text="{Binding Process.Result}" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                </Grid>
            </TabItem>

            <TabItem Header="Identity">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Refresh" Command="{Binding Identity.RefreshCommand}" />
                    </StackPanel>
                    <TextBox Grid.Row="1" Margin="0,10,0,0" Text="{Binding Identity.Text}" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                </Grid>
            </TabItem>

            <TabItem Header="Git Parser">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Parse" Command="{Binding GitParser.ParseCommand}" />
                    </StackPanel>

                    <TextBox Grid.Row="1" Margin="0,10,0,10" Text="{Binding GitParser.Raw, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                    <TextBox Grid.Row="2" Text="{Binding GitParser.Result}" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                </Grid>
            </TabItem>

            <TabItem Header="P2P Internals">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Refresh" Command="{Binding P2pInternals.RefreshCommand}" />
                    </StackPanel>
                    <TextBox Grid.Row="1" Margin="0,10,0,0" Text="{Binding P2pInternals.Text}" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                </Grid>
            </TabItem>

            <TabItem Header="Repos">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.ColumnSpan="2">
                        <TextBox Width="680" Text="{Binding Repos.Roots, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Content="Discover" Command="{Binding Repos.DiscoverCommand}" />
                        <Button Content="Load Registry" Command="{Binding Repos.LoadRegistryCommand}" />
                        <Button Content="Export" Command="{Binding Repos.ExportSnapshotCommand}" />
                        <Button Content="Import" Command="{Binding Repos.ImportSnapshotCommand}" />
                        <Button Content="Select All" Command="{Binding Repos.SelectAllCommand}" />
                        <Button Content="Clear" Command="{Binding Repos.ClearSelectionCommand}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0" Grid.ColumnSpan="2">
                        <Button Content="Refresh Git" Command="{Binding Repos.RefreshSelectedGitStatusCommand}" />
                        <Button Content="Scan Secrets" Command="{Binding Repos.ScanSelectedSecretsCommand}" />
                        <Button Content="OpenSourceify DryRun" Command="{Binding Repos.OpenSourceifyDryRunCommand}" />
                        <TextBox Width="60" Margin="10,0,0,0" Text="{Binding Repos.QueueConcurrency, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Content="Apply Concurrency" Command="{Binding Repos.ApplyConcurrencyCommand}" />
                        <Button Content="Pause" Command="{Binding Repos.PauseQueueCommand}" />
                        <Button Content="Resume" Command="{Binding Repos.ResumeQueueCommand}" />
                        <Button Content="Retry Failed" Command="{Binding Repos.RetryFailedCommand}" />
                        <Button Content="Clear Done" Command="{Binding Repos.ClearCompletedCommand}" />
                        <TextBlock Margin="10,6,0,0" Text="{Binding Repos.Status}" Foreground="{StaticResource Brush.Muted}" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,10" Grid.ColumnSpan="2">
                        <TextBox Width="520" Text="{Binding Repos.BatchDescription, UpdateSourceTrigger=PropertyChanged}" />
                        <CheckBox Margin="10,3,0,0" Content="Set Visibility" IsChecked="{Binding Repos.BatchSetVisibility}" />
                        <CheckBox Margin="10,3,0,0" Content="Private" IsChecked="{Binding Repos.BatchMakePrivate}" />
                        <Button Content="Update GitHub" Margin="10,0,0,0" Command="{Binding Repos.UpdateSelectedReposCommand}" />
                    </StackPanel>

                    <DataGrid Grid.Row="3" Grid.Column="0"
                              ItemsSource="{Binding Repos.Items}"
                              SelectedItem="{Binding Repos.Selected, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              SelectionUnit="FullRow">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="Sel" Binding="{Binding IsSelected, Mode=TwoWay}" Width="50" />
                            <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="*" />
                            <DataGridTextColumn Header="Git" Binding="{Binding GitSummary}" Width="220" />
                            <DataGridTextColumn Header="Origin" Binding="{Binding Remote}" Width="220" />
                            <DataGridTextColumn Header="GitHub" Binding="{Binding GitHubRepo}" Width="180" />
                            <DataGridTextColumn Header="Scan" Binding="{Binding LastScan}" Width="110" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="3" Grid.Column="1" Margin="10,0,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBox Text="{Binding Repos.Details}" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                        <TextBox Grid.Row="1" Margin="0,10,0,0" Text="{Binding Repos.QueueText}" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Tasks">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.ColumnSpan="2">
                        <Button Content="Refresh" Command="{Binding Tasks.RefreshCommand}" />
                        <TextBox Width="60" Margin="10,0,0,0" Text="{Binding Tasks.QueueConcurrency, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Content="Apply Concurrency" Command="{Binding Tasks.ApplyConcurrencyCommand}" />
                        <Button Content="Pause" Margin="10,0,0,0" Command="{Binding Tasks.PauseCommand}" />
                        <Button Content="Resume" Command="{Binding Tasks.ResumeCommand}" />
                        <Button Content="Retry Failed" Margin="10,0,0,0" Command="{Binding Tasks.RetryFailedCommand}" />
                        <Button Content="Clear Done" Command="{Binding Tasks.ClearCompletedCommand}" />
                        <Button Content="Cancel Selected" Margin="10,0,0,0" Command="{Binding Tasks.CancelSelectedCommand}" />
                    </StackPanel>

                    <DataGrid Grid.Row="1" Grid.Column="0" Margin="0,10,10,0"
                              ItemsSource="{Binding Tasks.Items}"
                              SelectedItem="{Binding Tasks.Selected, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              SelectionUnit="FullRow">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="State" Binding="{Binding State}" Width="90" />
                            <DataGridTextColumn Header="Kind" Binding="{Binding Kind}" Width="140" />
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Target" Binding="{Binding TargetKey}" Width="180" />
                            <DataGridTextColumn Header="Attempts" Binding="{Binding Attempts}" Width="80" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBox Grid.Row="1" Grid.Column="1" Margin="0,10,0,0"
                             Text="{Binding Tasks.Details}"
                             IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                </Grid>
            </TabItem>

            <TabItem Header="Logs">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Refresh" Command="{Binding Logs.RefreshCommand}" />
                    </StackPanel>
                    <TextBox Grid.Row="1" Margin="0,10,0,0" Text="{Binding Logs.Text}" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                </Grid>
            </TabItem>

            <TabItem Header="Git">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <TextBox Width="760" Text="{Binding Git.RepoPath, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Content="Refresh" Command="{Binding Git.RefreshCommand}" />
                    </StackPanel>

                    <TextBlock Grid.Row="1" Margin="0,10,0,10" Text="{Binding Git.Summary}" Foreground="{StaticResource Brush.Muted}" />

                    <TextBox Grid.Row="2" Text="{Binding Git.Details}" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                </Grid>
            </TabItem>

            <TabItem Header="gh CLI">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Refresh" Command="{Binding Gh.RefreshCommand}" />
                    </StackPanel>

                    <TextBlock Grid.Row="1" Margin="0,10,0,10" Text="{Binding Gh.Summary}" Foreground="{StaticResource Brush.Muted}" />

                    <TextBox Grid.Row="2" Text="{Binding Gh.Raw}" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                </Grid>
            </TabItem>

            <TabItem Header="GitHub Auth">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <TextBox Width="540" Text="{Binding GitHubAuth.TokenInput, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Content="Save Token" Command="{Binding GitHubAuth.SaveTokenCommand}" />
                        <Button Content="Clear" Command="{Binding GitHubAuth.ClearTokenCommand}" />
                        <Button Content="Refresh" Command="{Binding GitHubAuth.RefreshCommand}" />
                    </StackPanel>

                    <TextBlock Grid.Row="1" Margin="0,10,0,10" Text="{Binding GitHubAuth.Summary}" Foreground="{StaticResource Brush.Muted}" />

                    <TextBox Grid.Row="2" Text="{Binding GitHubAuth.Details}" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                </Grid>
            </TabItem>

            <TabItem Header="Database">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Migrate" Command="{Binding Database.MigrateCommand}" />
                        <Button Content="Refresh" Command="{Binding Database.RefreshCommand}" />
                    </StackPanel>

                    <TextBlock Grid.Row="1" Margin="0,10,0,10" Text="{Binding Database.Summary}" Foreground="{StaticResource Brush.Muted}" />

                    <TextBox Grid.Row="2" Text="{Binding Database.Details}" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                </Grid>
            </TabItem>

            <TabItem Header="Presence">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <TextBox Width="540" Text="{Binding Presence.Note, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Content="Publish" Command="{Binding Presence.PublishCommand}" />
                        <Button Content="Refresh" Command="{Binding Presence.RefreshCommand}" />
                    </StackPanel>

                    <TextBlock Grid.Row="1" Margin="0,10,0,10" Text="{Binding Presence.Summary}" Foreground="{StaticResource Brush.Muted}" />

                    <TextBox Grid.Row="2" Text="{Binding Presence.PeersText}" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                </Grid>
            </TabItem>

            <TabItem Header="P2P">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Start" Command="{Binding P2p.StartCommand}" />
                        <Button Content="Stop" Command="{Binding P2p.StopCommand}" />
                        <Button Content="Create Code" Command="{Binding P2p.CreateCodeCommand}" />
                        <TextBox Width="420" Text="{Binding P2p.InputCode, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Content="Trust" Command="{Binding P2p.TrustCommand}" />
                        <Button Content="Refresh" Command="{Binding P2p.RefreshCommand}" />
                    </StackPanel>

                    <TextBlock Grid.Row="1" Margin="0,10,0,10" Text="{Binding P2p.Summary}" Foreground="{StaticResource Brush.Muted}" />

                    <TextBox Grid.Row="2" Text="{Binding P2p.Details}" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                </Grid>
            </TabItem>

            <TabItem Header="File Transfer">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Refresh Peers" Command="{Binding FileTransfer.RefreshPeersCommand}" />
                        <ComboBox Width="520"
                                  ItemsSource="{Binding FileTransfer.Peers}"
                                  DisplayMemberPath="Display"
                                  SelectedValuePath="Thumbprint"
                                  SelectedValue="{Binding FileTransfer.SelectedPeerThumbprint, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,10">
                        <TextBox Width="720" Text="{Binding FileTransfer.FilePath, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Content="Select File" Command="{Binding FileTransfer.SelectFileCommand}" />
                        <Button Content="Send" Command="{Binding FileTransfer.SendCommand}" />
                    </StackPanel>

                    <TextBox Grid.Row="2" Text="{Binding FileTransfer.Log}" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                </Grid>
            </TabItem>

            <TabItem Header="Secret Scan">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <TextBox Width="760" Text="{Binding SecretScan.RepoPath, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Content="Scan" Command="{Binding SecretScan.ScanCommand}" />
                    </StackPanel>

                    <TextBlock Grid.Row="1" Margin="0,10,0,10" Text="{Binding SecretScan.Summary}" Foreground="{StaticResource Brush.Muted}" />

                    <TextBox Grid.Row="2" Text="{Binding SecretScan.Findings}" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                    <TextBox Grid.Row="3" Margin="0,10,0,0" Text="{Binding SecretScan.Raw}" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                </Grid>
            </TabItem>

            <TabItem Header="Updates">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Check" Command="{Binding Update.CheckCommand}" />
                    </StackPanel>

                    <TextBlock Grid.Row="1" Margin="0,10,0,10" Text="{Binding Update.Summary}" Foreground="{StaticResource Brush.Muted}" />

                    <TextBox Grid.Row="2" Text="{Binding Update.Raw}" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
